# ---------------------------------------------------------------------------
# PantryChef AI — environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is listed in .gitignore.
# ---------------------------------------------------------------------------

# Groq API key (default AI provider)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenAI API key (optional — only needed if you switch to the OpenAI provider)
# OPENAI_API_KEY=sk-...

# Ollama endpoint (optional — only needed for local inference)
# Defaults to http://localhost:11434 if not set
# OLLAMA_ENDPOINT=http://localhost:11434
